{
    "name": "ts-parcel-boilerplate",
    "version": "1.0.0",
    "description": "a boilerplate for TS and Snowpack bundler",
    "main": "index.tsx",
    "scripts": {
      "start": "snowpack dev",
      "build": "snowpack build",
      "clean": "rimraf ./build",
      "format": "prettier --write \"src/**/*.{js,jsx}\"",
      "lint": "prettier --check \"src/**/*.{js,jsx}\"",
      "test": "web-test-runner \"src/**/*.test.tsx\""
    },
    "keywords": [
      "parcel"
    ],
    "publishConfig": {
      "access": "public"
    },
    "author": "CMIV",
    "license": "GPLv3",
    "dependencies": {
      "preact": "^10.5.13"
    },
    "devDependencies": {
      "bulma": "^0.9.3",
      "rimraf": "^3.0.2",
      "typescript": "^4.3.4",
      "wouter-preact": "^2.7.4",
      "@prefresh/snowpack": "^3.0.0",
      "@snowpack/plugin-dotenv": "^2.1.0",
      "@snowpack/plugin-typescript": "^1.2.1",
      "@snowpack/web-test-runner-plugin": "^0.2.2",
      "@testing-library/preact": "^2.0.1",
      "@types/chai": "^4.2.17",
      "@types/mocha": "^8.2.2",
      "@types/snowpack-env": "2.3.3",
      "@web/test-runner": "^0.13.3",
      "chai": "^4.3.4",
      "prettier": "^2.2.1"
    },
    "alias": {
      "react": "preact-compat",
      "react-dom": "preact-compat"
    }
  }